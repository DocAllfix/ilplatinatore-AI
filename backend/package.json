{
  "name": "il-platinatore-ai-backend",
  "version": "0.1.0",
  "description": "Backend API per Il Platinatore AI — chatbot RAG per guide videoludiche",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
