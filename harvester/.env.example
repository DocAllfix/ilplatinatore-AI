# Database (stessa del backend — condivisa)
DATABASE_URL=postgresql://platinatore:password@pgbouncer:6432/platinatore_db

# Redis (database 1, separato dal backend che usa db 0)
REDIS_URL=redis://redis:6379/1

# API Keys
GEMINI_API_KEY=
GOOGLE_EMBEDDING_API_KEY=
DEEPSEEK_API_KEY=
# Transformer provider: deepseek (default) | gemini
TRANSFORMER_PROVIDER=deepseek

# PSN (opzionale — il sistema funziona anche senza)
# NPSSO: cookie da https://my.playstation.com/ dopo login (F12 → Application → Cookies)
PSN_NPSSO=

# IGDB (Twitch OAuth)
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Steam Web API (opzionale — achievements multilingua)
# Key gratuita da https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Harvester Config
HARVESTER_LOG_LEVEL=INFO
HARVESTER_DAILY_GEMINI_LIMIT=5000
HARVESTER_DAILY_EMBEDDING_LIMIT=50000
HARVESTER_SCRAPE_DELAY_SECONDS=3.0
HARVESTER_MAX_CONCURRENT_COLLECTORS=3
HARVESTER_USER_AGENT=IlPlatinatoreBot/1.0 (+https://ilplatinatore.it/bot)
