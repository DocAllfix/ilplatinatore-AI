# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template variabili d'ambiente per Il Platinatore AI
# Copia in .env e sostituisci TUTTI i placeholder prima di avviare il progetto.
# IMPORTANTE: .env NON deve mai essere committato (è in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Connessione applicazione via PgBouncer (pooling — porta 6432)
DATABASE_URL=postgresql://platinatore:password@pgbouncer:6432/platinatore_db

# AUDIT FIX (Warning #6): Connessione diretta per migration (solo via docker compose exec, mai dall'host)
POSTGRES_DIRECT_URL=postgresql://platinatore:password@postgres:5432/platinatore_db
POSTGRES_DB=platinatore_db
POSTGRES_USER=platinatore
POSTGRES_PASSWORD=CAMBIAMI_CON_PASSWORD_SICURA

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── API Keys ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
SERPAPI_KEY=
GOOGLE_EMBEDDING_API_KEY=

# ── WordPress ─────────────────────────────────────────────────────────────────
WP_API_URL=https://www.ilplatinatore.it/wp-json/wp/v2
WP_APP_PASSWORD=
WP_WEBHOOK_SECRET=

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CAMBIAMI_CON_STRINGA_RANDOM_64_CHAR
JWT_REFRESH_SECRET=CAMBIAMI_CON_ALTRA_STRINGA_RANDOM

# AUDIT FIX (R2): CSRF signed-token HMAC secret — DIVERSO da JWT_SECRET
CSRF_SECRET=CAMBIAMI_STRINGA_RANDOM_64_CHAR_DEDICATA_AL_CSRF

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PLATINUM=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3001,https://ai.ilplatinatore.it,https://www.ilplatinatore.it

# ── IGDB (opzionale — abilitato dalla Fase 8) ────────────────────────────────
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# ── Steam Web API (opzionale — Steam Community Guides) ───────────────────────
STEAM_API_KEY=

# ── YouTube Data API v3 (opzionale — video guide transcripts) ────────────────
# Crea key su: https://console.cloud.google.com → YouTube Data API v3
# Quota gratuita: 10.000 units/giorno. Default limit: 8000 units (20% buffer).
YOUTUBE_API_KEY=
HARVESTER_DAILY_YOUTUBE_QUOTA_LIMIT=8000

# ── Harvester (Python ingestion engine) ───────────────────────────────────────
# REDIS_URL per l'harvester è fisso a redis://redis:6379/1 nel docker-compose
# (database 1, separato dal backend che usa db=0)
HARVESTER_LOG_LEVEL=INFO
HARVESTER_DAILY_GEMINI_LIMIT=5000
HARVESTER_DAILY_EMBEDDING_LIMIT=50000

# ── RAG Config (NON hardcodare nel codice) ────────────────────────────────────
RAG_SIMILARITY_THRESHOLD_HIGH=0.85
RAG_SIMILARITY_THRESHOLD_LOW=0.60
RAG_MAX_RESULTS=5
EMBEDDING_DIMENSION=768

# ── Rate Limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_FREE_DAILY=3
RATE_LIMIT_FREE_REGISTERED_DAILY=5
RATE_LIMIT_PRO_PER_MINUTE=10
